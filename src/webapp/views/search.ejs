<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= query %> - SearchHub</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background-color: #ffffff;
      color: #202124;
    }
    .header {
      display: flex;
      align-items: center;
      padding: 6px 20px;
      border-bottom: 1px solid #dadce0;
    }
    .logo {
      font-size: 28px;
      font-weight: 400;
      margin-right: 30px;
      background: linear-gradient(135deg, #4285F4 0%, #EA4335 25%, #FBBC04 50%, #34A853 75%, #EA4335 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-decoration: none;
      cursor: pointer;
    }
    .search-box {
      flex: 1;
      max-width: 584px;
      display: flex;
      border: 1px solid #dadce0;
      border-radius: 24px;
      padding: 8px 16px;
    }
    .search-box:hover {
      box-shadow: 0 1px 6px rgba(32,33,36,.28);
    }
    .search-box input {
      flex: 1;
      border: none;
      outline: none;
      font-size: 16px;
    }
    .search-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
    }
    .tools {
      margin-left: auto;
      display: flex;
      gap: 15px;
    }
    .tools a {
      color: rgba(0,0,0,0.87);
      text-decoration: none;
      font-size: 14px;
    }
    .tools a:hover {
      text-decoration: underline;
    }
    .container {
      max-width: 600px;
      margin: 40px auto;
      padding: 0 20px;
    }
    .result-stats {
      color: #70757a;
      font-size: 14px;
      margin-bottom: 20px;
    }
    .error {
      color: #dc3545;
      text-align: center;
      padding: 30px;
    }
    .result {
      margin-bottom: 30px;
    }
    .result-url {
      color: #006621;
      font-size: 13px;
      display: flex;
      align-items: center;
      margin-bottom: 3px;
    }
    .result h3 {
      font-size: 20px;
      font-weight: 400;
      margin: 0 0 8px 0;
      line-height: 1.3;
    }
    .result h3 a {
      color: #1967d2;
      text-decoration: none;
      cursor: pointer;
    }
    .result h3 a:hover {
      text-decoration: underline;
    }
    .result-description {
      color: #545454;
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 5px;
    }
    .result-score {
      color: #70757a;
      font-size: 12px;
      margin-top: 5px;
    }
    .pagination {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 30px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .pagination a, .pagination span {
      padding: 8px 12px;
      text-decoration: none;
      color: #1967d2;
      font-size: 14px;
    }
    .pagination a:hover {
      text-decoration: underline;
    }
    .pagination span {
      color: #202124;
      font-weight: bold;
    }
    @media (max-width: 768px) {
      .header {
        flex-direction: column;
        gap: 10px;
        padding: 10px;
      }
      .logo {
        font-size: 24px;
        margin-right: 0;
      }
      .search-box {
        max-width: 100%;
        flex: 1;
      }
      .tools {
        margin-left: 0;
        justify-content: center;
        width: 100%;
        gap: 10px;
      }
      .tools a {
        font-size: 12px;
      }
      .container {
        max-width: 90vw;
        margin: 20px auto;
      }
      .result h3 {
        font-size: 18px;
      }
      .result-description {
        font-size: 13px;
      }
      .result-url {
        font-size: 12px;
      }
    }
    @media (max-width: 480px) {
      .header {
        padding: 8px;
      }
      .logo {
        font-size: 20px;
      }
      .search-box {
        padding: 6px 12px;
      }
      .search-box input {
        font-size: 14px;
      }
      .tools a {
        font-size: 11px;
      }
      .container {
        max-width: 100%;
        margin: 15px 10px;
        padding: 0 10px;
      }
      .result-stats {
        font-size: 12px;
      }
      .result h3 {
        font-size: 16px;
      }
      .result-description {
        font-size: 12px;
        line-height: 1.5;
      }
      .result-url {
        font-size: 11px;
      }
      .result-score {
        font-size: 11px;
      }
      .pagination {
        gap: 5px;
      }
      .pagination a, .pagination span {
        padding: 6px 10px;
        font-size: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <a href="/" class="logo">SearchHub</a>
    <form action="/search" method="GET" class="search-box">
      <input type="text" name="q" value="<%= query %>" required>
      <button type="submit" class="search-btn">🔍</button>
    </form>
    <div class="tools">
      <a href="#">Paramètres</a>
      <a href="#">À propos</a>
    </div>
  </div>
  <div class="container">
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } else if (results && results.length > 0) { %>
      <div class="result-stats">Environ <%= total %> résultats (0,<%= Math.floor(Math.random() * 1000) -%> secondes)</div>
      <% results.forEach(result => { %>
        <div class="result">
          <div class="result-url"><%= result.url.substring(0, 60) %></div>
          <h3><a href="<%= result.url %>" target="_blank"><%= result.title || result.url %></a></h3>
          <div class="result-description"><%= result.content_part || (result.meta_description || 'Pas de description disponible') %></div>
          <div class="result-score">Pertinence: <%= (result.score.toFixed(2)) %></div>
        </div>
      <% }); %>
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= currentPage - 1 %>">← Précédent</a>
          <% } %>
          <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
            <% if (i === currentPage) { %>
              <span><%= i %></span>
            <% } else { %>
              <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= i %>"><%= i %></a>
            <% } %>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= currentPage + 1 %>">Suivant →</a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="error">Aucun résultat trouvé pour "<%= query %>".</div>
    <% } %>
  </div>
  <% console.log(error) %>
</body>
</html>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SearchHub - Moteur de recherche</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background-color: #ffffff;
      color: #202124;
    }
    .header {
      padding: 20px;
      text-align: right;
    }
    .header a {
      margin-left: 25px;
      color: rgba(0,0,0,0.87);
      text-decoration: none;
      font-size: 14px;
    }
    .header a:hover {
      text-decoration: underline;
    }
    .container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      height: calc(100vh - 60px);
      padding: 20px;
    }
    .logo {
      margin-bottom: 20px;
    }
    .logo-text {
      font-size: 92px;
      font-weight: 400;
      text-align: center;
      background: linear-gradient(135deg, #4285F4 0%, #EA4335 25%, #FBBC04 50%, #34A853 75%, #EA4335 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI';
    }
    .search-container {
      width: 100%;
      max-width: 584px;
      margin: 20px 0;
    }
    .search-box {
      display: flex;
      border: 1px solid #dadce0;
      border-radius: 24px;
      padding: 10px 20px;
      background-color: #ffffff;
      box-shadow: 0 2px 5px 1px rgba(64,60,57,.16);
    }
    .search-box:hover {
      box-shadow: 0 2px 8px 1px rgba(64,60,57,.24);
    }
    .search-box input {
      flex: 1;
      border: none;
      outline: none;
      font-size: 16px;
      padding: 0 10px;
    }
    .button-container {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 30px;
    }
    button {
      background-color: #f8f9fa;
      border: 1px solid #f8f9fa;
      border-radius: 4px;
      color: #3c4043;
      font-size: 14px;
      margin: 11px 4px;
      padding: 10px 24px;
      cursor: pointer;
      font-weight: 500;
    }
    button:hover {
      box-shadow: 0 1px 1px rgba(0,0,0,.1);
      background-color: #f8f9fa;
      border: 1px solid #dadce0;
      color: #202124;
    }
    .github-btn {
      display: inline-flex;
      align-items: center;
      background-color: #f8f9fa;
      border: 1px solid #f8f9fa;
      border-radius: 4px;
      color: #3c4043;
      font-size: 14px;
      margin: 11px 4px;
      padding: 10px 24px;
      cursor: pointer;
      font-weight: 500;
      text-decoration: none;
    }
    .github-btn:hover {
      box-shadow: 0 1px 1px rgba(0,0,0,.1);
      background-color: #f8f9fa;
      border: 1px solid #dadce0;
      color: #202124;
    }
    .footer {
      position: absolute;
      bottom: 0;
      width: 100%;
      background-color: #f2f2f2;
      padding: 15px 20px;
      font-size: 14px;
      color: #70757a;
      border-top: 1px solid #dadce0;
    }
    .footer-section {
      display: flex;
      flex-wrap: wrap;
      gap: 25px;
    }
    .footer a {
      color: #70757a;
      text-decoration: none;
    }
    .footer a:hover {
      color: #202124;
    }
  </style>
</head>
<body>
  <div class="header">
    <a href="#">À propos de SearchHub</a>
    <a href="#">Paramètres</a>
  </div>
  <div class="container">
    <div class="logo">
      <div class="logo-text">SearchHub</div>
    </div>
    <form action="/search" method="GET" class="search-container">
      <div class="search-box">
        <input type="text" name="q" placeholder="Cherchez sur SearchHub..." required>
      </div>
      <div class="button-container">
        <button type="submit">Recherche SearchHub</button>
        <a href="https://github.com/faouz-dev/project-search-engine" target="_blank" class="github-btn">GitHub Repo</a>
      </div>
    </form>
  </div>
  <div class="footer">
    <div class="footer-section">
      <a href="#">Publicité</a>
      <a href="#">Entreprise</a>
      <a href="#">À propos</a>
      <a href="#">Comment fonctionne la recherche</a>
      <a href="#">Confidentialité</a>
      <a href="#">Conditions</a>
    </div>
  </div>
</body>
</html>